[
    {
        "title": "言兴",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "矻矻被吟牵，因师贾浪仙。江山风月处，一十二三年。",
            "雅颂在於此，浮华致那边。犹惭功未至，谩道近千篇。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 1
    },
    {
        "title": "江上秋思",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "到来江上久，谁念旅游心。故国无秋信，邻家有夜砧。",
            "坐遥翻不睡，愁极却成吟。即恐髭连鬓，还为白所侵。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 2
    },
    {
        "title": "匡山居",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "无才加性拙，道理合藏踪。是处非深远，其山已万重。",
            "经时邻境戰，独夜隔云舂。昨日泉中见，常鱼亦化龙。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 3
    },
    {
        "title": "夷陵即事",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "不难饶白发，相续是滩波。避世嫌身晚，思家乞梦多。",
            "暑衣经雪著，冻砚向阳呵。岂谓临岐路，还闻圣主过。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 4
    },
    {
        "title": "紫阁隐者",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "天高紫阁侵，隐者信沉沉。道长年兼长，云深草复深。",
            "如非禅客见，即是猎人寻。北笑长安道，埃尘古到今。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 5
    },
    {
        "title": "与陈陶处士",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "钟陵城外住，喻似玉沈泥。道直贫嫌杀，神清语亦低。",
            "雪深加酒债，春尽减诗题。记得曾邀宿，山茶独自携。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 6
    },
    {
        "title": "与王嵩隐",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "一生吟兴僻，方见业精微。事若终难得，乡应不易归。",
            "乱收西日叶，双掩北风扉。合国诸卿相，皆曾著布衣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 7
    },
    {
        "title": "怀陆龟蒙处士",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "布褐东南隐，相传继谢敷。高谭夫子道，静看海山图。",
            "事免伤心否，棋逢敌手无。关中花数内，独不见菖蒲。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 8
    },
    {
        "title": "寄华阴司空侍郎",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "剑佩已深扃，茅为岳面亭。诗犹少绮美，畫肯爱丹青。",
            "换笔修僧史，焚香阅道经。相邀来未得，但想鹤仪形。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 9
    },
    {
        "title": "送陆肱入关",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "舟行复陆行，始得到咸京。准拟何人口，吹嘘六义名。",
            "乱山遥减翠，丛菊早含英。衣锦还乡日，他时有此荣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 10
    },
    {
        "title": "送刘必先",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "力进凭诗业，心焦阙问安。远行无处易，孤立本来难。",
            "楚月船中没，秦星马上残。明年有公道，更以命推看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 11
    },
    {
        "title": "寄方干处士",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "格外缀清诗，诗名独得知。閒居公道日，醉卧牡丹时。",
            "海鸟和涛望，山僧带雪期。仍闻称处士，圣主肯相违。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 12
    },
    {
        "title": "寄刘逸士",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "无愁无累者，偶向市朝游。此后乘孤艇，依前入乱流。",
            "高眠歌圣日，下钓坐清秋。道不离方寸，而能混俗求。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 13
    },
    {
        "title": "送独孤处士",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "万里去非忙，惟携贮药囊。山家宵夜景，酒肆过年光。",
            "立鹤洲侵浪，喧蛩壁近床。谁人临上路，乞得变髭方。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 14
    },
    {
        "title": "早春送人归岳阳",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "久食主人鱼，春来复旧居。远无千里浪，轻有半船书。",
            "过片晴云淡，消残暮雪虚。岳阳多异境，搜思勿令疏。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 15
    },
    {
        "title": "冬暮送人",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "长安冬欲尽，又送一遗贤。醉后情浑可，言休理不然。",
            "射衣秦岭雪，摇月汉江船。亦过春兼夏，回期信有蝉。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 16
    },
    {
        "title": "送徐道人东游",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "长安人扰扰，独自有閒心。海上山中去，风前月下吟。",
            "引猿秋果熟，藏鹤晓云深。易姓更名数，难教弟子寻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 17
    },
    {
        "title": "自纪",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "诸机忘尽未忘诗，似向诗中有所依。远境等閒支枕觅，",
            "欲畫净名居士像，焚香願见陆探微。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 18
    },
    {
        "title": "怀智栖上人",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "临水登山自有期，不同游子暮何之。闲眠默坐身堪赏，",
            "思君最易令人老，倚槛空吟所寄诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 19
    },
    {
        "title": "峡中酬荆南郑准",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "山斋西向蜀江𣸣，四载安居复有群。风雁势高犹可见，",
            "每喜溯流宾客说，元瑜刀笔润雄军。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 20
    },
    {
        "title": "寄荆门郑准",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "传衣传钵理难论，绮靡销磨二雅尊。不许姓名留月观，",
            "珍重荆门郑从事，十年同受景升恩。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 21
    },
    {
        "title": "将欲再游荆渚留辞岐下司徒",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "竹锡铜瓶配衲衣，殷公楼畔偶然离。白莲几看从開日，",
            "今朝回去精神别，为得头厅宰相诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 22
    },
    {
        "title": "赠村公",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "绸衣木突此乡尊，白尽须眉眼未昏。醉舞神筵随鼓笛，",
            "也笑长安名利处，红尘半是马蹄翻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 23
    },
    {
        "title": "秋夜吟",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "梧桐雨畔夜愁吟，抖擞衣裾藓色侵。",
            "枉道一生无系著，湘南山水别人寻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 24
    },
    {
        "title": "读齐己上人集",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "诗为儒者禅，此格的惟仙。古雅如周颂，清和甚舜弦。",
            "冰生听瀑句，香发早梅篇。想得吟成夜，文星照楚天。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 25
    },
    {
        "title": "除夜",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "九冬三十夜，寒与暖分開。坐到四更后，身添一岁来。",
            "鱼灯延腊火，兽炭化春灰。青帝今应老，迎新见几回。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 26
    },
    {
        "title": "送人归乡",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "多才与命违，末路忆柴扉。白发何人问，青山一剑归。",
            "晴烟独鸟没，野渡乱花飞。寂寞长亭外，依然空落晖。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 27
    },
    {
        "title": "述怀",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "青门聊极望，何事久离群。芳草失归路，故乡空暮云。",
            "信回陵树老，梦断灞流分。兄弟正南北，鸿声堪独闻。",
            "五城初罢构，海上忆闲行。触雪麻衣静，登山竹锡轻。",
            "天寒岳寺出，日晚岛泉清。坐与幽期遇，何湖心渺冥。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 28
    },
    {
        "title": "宿寿安甘棠馆",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "行人方倦役，到此似还乡。流水来关外，青山近洛阳。",
            "溪云归洞鹤，松月半轩霜。坐恐晨钟动，天涯道路长。",
            "山空蕙气香，乳管折云房。願值壶中客，亲传肘后方。",
            "三更礼星斗，寸匕服丹霜。默坐树阴下，仙经横石床。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 29
    },
    {
        "title": "送朴山人归新罗",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "浩渺行无极，扬帆但信风。云山过海半，乡树入舟中。",
            "波定遥天出，沙平远岸穷。离心寄何处，目击曙霞东。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 30
    },
    {
        "title": "宿清远峡山寺",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "寺近朝天路，多闻玉佩音。鉴人開慧眼，归鸟息禅心。",
            "磬接星河曙，窗连夏木深。此中能宴坐，何必在云林。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 31
    },
    {
        "title": "松山岭",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "平生闲放久，野鹿许为群。居止邻西岳，轩窗度白云。",
            "斋心饭松子，话道接茅君。汉主恩情去，空山起夕氛。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 32
    },
    {
        "title": "句",
        "author": "尚颜",
        "biography": "",
        "paragraphs": [
            "浸浸三楚白，渺渺九江寒。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 33
    },
    {
        "title": "泊洞庭",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "槐柳未知秋，依依馆驿头。客心俱念远，时雨自相留。",
            "浪没货鱼市，帆高卖酒楼。夜来思辗转，故里在南州。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 34
    },
    {
        "title": "善卷坛",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "耕荒凿原时，高趣在希夷。大舜欲逊国，先生空敛眉。",
            "五溪清不足，千古美无亏。纵遣亡淳者，何人投所思。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 35
    },
    {
        "title": "石城金谷",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "晋祚一倾摧，骄奢去不回。只应荆棘地，犹作绮罗灰。",
            "狐兔闲生长，樵苏静往来。踟蹰意无尽，寒日又西颓。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 36
    },
    {
        "title": "庾楼",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "郡楼名甚远，几换见楼人。庾亮魂应在，清风到白蘋。",
            "晴轩分楚汉，夜酒揖星辰。何必匡山上，独言无世尘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 37
    },
    {
        "title": "经贺监旧居",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "不恋明皇宠，归来镜水隅。道装汀鹤识，春醉钓人扶。",
            "逐朵云如吐，成行雁侣驱。兰亭名景在，踪迹未为孤。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 38
    },
    {
        "title": "献郑都官",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "早晚辞班列，归寻旧隐峰。代移家集在，身老诏书重。",
            "药秘仙都诀，茶開蜀国封。何当答群望，高蹑傅岩踪。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 39
    },
    {
        "title": "寄华山司空图二首",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "门径放莎垂，往来投刺稀。有时開御劄，特地挂朝衣。",
            "岳信僧传去，仙香鹤带归。他年二南化，无复更衰微。",
            "逍遥短褐成，一剑动精灵。白昼梦仙岛，清晨礼道经。",
            "黍苗侵野径，桑椹污閒庭。肯要为邻者，西南太华青。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 40
    },
    {
        "title": "赠屏风岩栖蟾上人",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "岩房高且静，住此几寒暄。鹿嗅安禅石，猿啼乞食村。",
            "朝阳生树罅，古路透云根。独我闲相觅，凄凉碧洞门。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 41
    },
    {
        "title": "赠秀才",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "筠阳多胜致，夫子纵游遨。凤鸟瑞不见，鲈鱼价转高。",
            "门開沙觜静，船系树根牢。谁解伊人趣，村沽对郁陶。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 42
    },
    {
        "title": "送迁客",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "倏忽堕鹓行，天南去路长。片言曾不谄，获罪亦何伤。",
            "象恋藏牙浦，人贪卖子乡。此心终合雪，去已莫思量。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 43
    },
    {
        "title": "哭悼朝贤",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "前昨回私第，旋闻寝疾终。四邻方响绝，二月牡丹空。",
            "冢已迁名境，碑仍待至公。只应遗爱理，长在楚南风。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 44
    },
    {
        "title": "悼方干处士",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "先生在世日，只向镜湖居。明主未巡狩，白头闲钓鱼。",
            "烟莎一径小，洲岛四邻疏。独有为儒者，时来吊旧廬。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 45
    },
    {
        "title": "听轩辕先生琴",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "诀妙与功精，通宵膝上横。一堂风冷淡，千古意分明。",
            "坐客神魂凝，巢禽耳目倾。酷哉商纣世，曾不遇先生。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 46
    },
    {
        "title": "芳草",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "绵绵芳草绿，何处动深思。金谷人亡后，沙场日暖时。",
            "龙鳞藏有瑞，风雨洒无私。欲采兰兼蕙，清香可赠谁。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 47
    },
    {
        "title": "句",
        "author": "虚中",
        "biography": "",
        "paragraphs": [
            "喜鱼在深处，幽鸟立多时。",
            "菖蒲花不艳，鸲鹆性多灵。",
            "盘中是祥瑞，天下恰炎蒸。",
            "待暖还须去，门前有路岐。",
            "春雨无高下，花枝有短长。",
            "老负峨眉月，闲看云水心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 48
    },
    {
        "title": "短歌行",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "蟾光堪自笑，浮世懒思量。身得几时活，眼開终日忙。",
            "千门无寿药，一镜有愁霜。早向尘埃外，光阴任短长。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 49
    },
    {
        "title": "除夜",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "九冬三十夜，寒与暖分開。坐到四更后，身添一岁来。",
            "鱼灯延腊火，兽炭化春灰。青帝今应老，迎新见几回。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 50
    },
    {
        "title": "宿巴江",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "江声五十里，泻碧急於弦。不觉日又夜，争教人少年。",
            "一汀巫峡月，两岸子规天。山影似相伴，浓遮到晓船。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 51
    },
    {
        "title": "游边",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "边云四顾浓，饥马嗅枯丛。万里八九月，一身西北风。",
            "偷营天正黑，戰地雪多红。昨夜东归梦，桃花暖色中。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 52
    },
    {
        "title": "居南岳怀沈彬",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "石房開竹扉，茗外独支颐。万木还无叶，百年能几时。",
            "隔云闻狖过，截雨见虹垂。因忆岳南客，晏眠吟好诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 53
    },
    {
        "title": "南中怀友生",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "荔枝江上立，望北几思量。隔海无书劄，前年在汉阳。",
            "瘴村人起早，铜柱象揩光。居此成何事，寻君过碧湘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 54
    },
    {
        "title": "赠南岳玄泰布衲",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "曹溪入室人，终老甚难群。四十餘年内，青山与白云。",
            "松和巢鹤看，果共野猿分。海外僧来说，名高自小闻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 55
    },
    {
        "title": "寄问政山聂威仪",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "先生卧碧岑，诸祖是知音。得道无一法，孤云同寸心。",
            "岚光熏鹤诏，茶味敌人参。苦向壶中去，他年许我寻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 56
    },
    {
        "title": "送迁客",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "諫频甘得罪，一骑入南深。若顺吾皇意，即无臣子心。",
            "织花蛮市布，捣月象州砧。蒙雪知何日，凭楼望北吟。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 57
    },
    {
        "title": "读齐己上人集",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "诗为儒者禅，此格的惟仙。古雅如周颂，清和甚舜弦。",
            "冰生听瀑句，香发早梅篇。想得吟成夜，文星照楚天。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 58
    },
    {
        "title": "牧童",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "牛得自由骑，春风细雨飞。青山青草里，一笛一蓑衣。",
            "日出唱歌去，月明抚掌归。何人得似尔，无是亦无非。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 59
    },
    {
        "title": "再宿京口禅院",
        "author": "栖蟾",
        "biography": "",
        "paragraphs": [
            "滩声依旧水溶溶，岸影参差对梵宫。楚树七回凋旧叶，",
            "多病支郎念行止，晚年生计转如蓬。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷八百四十八",
        "no#": 60
    }
]