[
    {
        "title": "题吕食新水阁兼寄南商州郎中",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "丹槛初结构，孤高冠清川。庭临谷中树，簷落山上泉。",
            "晓色挂残月，夜声杂繁弦。青春去如水，康乐归何年。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 1
    },
    {
        "title": "华山南望春",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "灵岳多异状，巉巉出虚空。闲云恋岩壑，起灭苍翠中。",
            "皓气澄野水，神光秘琼宫。鹤巢前林雪，瀑落满涧风。",
            "春尽花未发，川回路难穷。何因著山屐，鹿迹寻羊公。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 2
    },
    {
        "title": "水阁",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "楼居半池上，澄影共相空。谢守题诗处，莲開净碧中。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 3
    },
    {
        "title": "迎风亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "山雨留清气，溪飙送早凉。时回石门步，阶下碧云光。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 4
    },
    {
        "title": "双槠亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "连簷对双树，冬翠夏无尘。未肯惭桃李，成阴不待春。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 5
    },
    {
        "title": "莲亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "回塘最幽处，拍水小亭開。莫怪阑干湿，䴔䴖夜宿来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 6
    },
    {
        "title": "中峰亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "中峰上翠微，窗晓早霞飞。几引登山屐，春风踏雪归。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 7
    },
    {
        "title": "飞云亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "上结孤圆顶，飞轩出泰清。有时迷处所，梁栋晓云生。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 8
    },
    {
        "title": "四望亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "高亭群峰首，四面俯晴川。每见晨光晓，阶前万井烟。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 9
    },
    {
        "title": "望莲台",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "秋台好登望，菡萏发清池。半似红颜醉，凌波欲暮时。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 10
    },
    {
        "title": "茶亭",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "静得尘埃外，茶芳小华山。此亭真寂寞，世路少人闲。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 11
    },
    {
        "title": "宿新安村步",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "淅淅寒流涨浅沙，月明空渚遍芦花。",
            "离人偶宿孤村下，永夜闻砧一两家。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 12
    },
    {
        "title": "远闻本郡行春到旧山二首",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "一身从宦留京邑，五马遥闻到旧山。",
            "已领烟霞光野径，深惭老幼候柴关。",
            "清风借响松筠外，畫隼停晖水石间。",
            "定掩溪名在图传，共知轩盖此登攀。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 13
    },
    {
        "title": "和崔使君临发不得观积雪",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "贫居稍与池塘近，旬日轩车不降来。",
            "一树琼花空有待，晓风看落满青苔。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 14
    },
    {
        "title": "句",
        "author": "朱景玄",
        "biography": "",
        "paragraphs": [
            "塞鸿先秋去，边草入夏生。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 15
    },
    {
        "title": "别青州妓段东美",
        "author": "薛宜僚",
        "biography": "",
        "paragraphs": [
            "经年邮驿许安栖，一会他乡别恨迷。",
            "今日海帆飘万里，不堪肠断对含啼。",
            "阿母桃花方似锦，王孙草色正如烟。",
            "不须更向沧溟望，惆怅欢情恰一年。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 16
    },
    {
        "title": "咏韦皋",
        "author": "郭圆",
        "biography": "",
        "paragraphs": [
            "宣父从周又适秦，昔贤谁少出风尘。",
            "当时甚讶张延赏，不识韦皋是贵人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 17
    },
    {
        "title": "进宣宗收复河湟诗",
        "author": "崔铉",
        "biography": "",
        "paragraphs": [
            "边陲万里注恩波，宇宙群芳洽凯歌。右地名王争解辫，",
            "共遇圣明千载运，更观俗阜与时和。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 18
    },
    {
        "title": "咏架上鹰",
        "author": "崔铉",
        "biography": "",
        "paragraphs": [
            "天边心胆架头身，欲拟飞腾未有因。",
            "万里碧霄终一去，不知谁是解绦人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 19
    },
    {
        "title": "越亭二十韵",
        "author": "元晦",
        "biography": "",
        "paragraphs": [
            "乏才叨八使，徇禄非三顾。南服颁诏条，东林证迷误。",
            "未闻述职效，偶脱嚣烦趣。激水浚坳塘，缘崖欹磴步。",
            "西岩焕朝旭，深壑囊宿雾。影气爽衣巾，凉飔轻杖履。",
            "临高神虑寂，远眺川原布。孤帆逗汀烟，翻鸦集江树。",
            "独探洞府静，恍若偓佺遇。一瞬契真宗，百年成妄故。",
            "孱颜石户启，杳霭溪云度。松籁韵宫商，鸳甍势翔溯。",
            "津梁危彴架，济物虚舟渡。环流驰羽觞，金英妒妆嫭。",
            "笳吟寒垒迥，鸟噪空山暮。怅望麋鹿心，低回车马路。",
            "悬冠谢陶令，褫佩怀疏傅。遐想蜕缨緌，徒惭恤襦袴。",
            "福盈祸之倚，权胜道所恶。何必栖禅关，无言自冥悟。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 20
    },
    {
        "title": "除浙东留题桂郡林亭",
        "author": "元晦",
        "biography": "",
        "paragraphs": [
            "紫泥远自金銮降，朱旆翻驰镜水头。陶令风光偏畏夜，",
            "莫遣艳歌催客醉，不堪回首翠蛾愁。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 21
    },
    {
        "title": "句",
        "author": "元晦",
        "biography": "",
        "paragraphs": [
            "石静如開镜，山高若耸莲。笋竿抽玉管，花蔓缀金钿。",
            "。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 22
    },
    {
        "title": "和元常侍除浙东留题",
        "author": "路贯",
        "biography": "",
        "paragraphs": [
            "谢安致理逾三载，黄霸清声彻九重。犹辍佩环归凤阙，",
            "共喜甘棠有新咏，独惭霜鬓又攀龙。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 23
    },
    {
        "title": "赠巩畴",
        "author": "郑熏",
        "biography": "",
        "paragraphs": [
            "密雪松桂寒，书窗导餘清。风撼冰玉碎，阶前琴磬声。",
            "榻静几砚洁，帙散缣缃明。高论展僧肇，精言资巩生。",
            "立意加玄虚，析理分纵横。万化悉在我，一物安能惊。",
            "江海何所动，丘山常自平。迟速不相阂，后先徒起争。",
            "镜照分妍丑，秤称分重轻。颜容宁入鉴，铢两岂关衡。",
            "蕴微道超忽，剖镫音泠泠。纸上掣牢键，舌端摇利兵。",
            "圆澈保直性，客尘排妄情。有住即非住，无行即是行。",
            "疏越舍朱弦，哇淫鄙秦筝。淡薄贵无味，羊斟惭大羹。",
            "洪远包乾坤，幽窅潜沈冥。罔烦跬步举，顿达万里程。",
            "廬远尚莫晓，隐留曾误听。直须持妙说，共诣毗耶城。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 24
    },
    {
        "title": "句",
        "author": "郑熏",
        "biography": "",
        "paragraphs": [
            "项斯逢水部，谁道不关情。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷五百四十七",
        "no#": 25
    }
]