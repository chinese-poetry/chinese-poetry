[
    {
        "title": "中酒寄刘行军",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "甚矣频频醉，神昏体亦虚。肺伤徒问药，发落不盈梳。",
            "恋寝嫌明室，修生愧道书。西峰老僧语，相劝合何如。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 1
    },
    {
        "title": "白雁",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "东溪一白雁，毛羽何皎洁。薄暮浴清波，斜阳共明灭。",
            "差池失群久，幽独依人切。旅食赖菰蒲，单栖怯霜雪。",
            "边风昨夜起，顾影空哀咽。不及墙上乌，相将绕双阙。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 2
    },
    {
        "title": "早春寄怀",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "家山归未得，又是看春过。老觉光阴速，闲悲世路多。",
            "风和吹岸柳，雪尽见庭莎。欲向东溪醉，狂眠一放歌。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 3
    },
    {
        "title": "春日东山正堂作",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "身闲赢得出，天气渐暄和。蜀马登山稳，南朝古寺多。",
            "早花微弄色，新酒欲生波。从此唯行乐，閒愁奈我何。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 4
    },
    {
        "title": "春日小园晨看兼招同舍",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "最有杏花繁，枝枝若手抟。须知一春促，莫厌百回看。",
            "鸟啭风潜息，蜂迟露未干。可容排饮否，兼折赠头冠。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 5
    },
    {
        "title": "惜花寄孙员外",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "朝始一枝開，暮复一枝落。只恐雨淋漓，又见春萧索。",
            "侵晨结驷携酒徒，寻芳踏尽长安衢。思量少壮不自乐，"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 6
    },
    {
        "title": "春日病中",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "才得归闲去，还教病卧频。无由全胜意，终是负青春。",
            "绿柳渐拂地，黄莺如唤人。方为医者劝，断酒已经旬。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 7
    },
    {
        "title": "殴妓",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "自为专房甚，匆匆有所伤。当时心已悔，彻夜手犹香。",
            "恨枕堆云髻，啼襟揾月黄。起来犹忍恶，剪破绣鸳鸯。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 8
    },
    {
        "title": "踏青樽前",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "期君速行乐，不要旋还家。永日虽无雨，东风自落花。",
            "诗毫粘酒淡，歌袖向人斜。薄暮忘归路，垂杨噪乱鸦。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 9
    },
    {
        "title": "正月晦日",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "莫倦寻春去，都无百日游。更堪正月过，已是一分休。",
            "泉暖声才出，云寒势未收。晚来重作雪，翻为杏花愁。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 10
    },
    {
        "title": "惜花",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "白发今如此，红芳莫更催。预愁多日谢，翻怕十分開。",
            "点滴无时雨，荒凉满地苔。闲阶一杯酒，惟待故人来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 11
    },
    {
        "title": "金谷园落花",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "愁见清明后，纷纷盖地红。惜看难过日，自落不因风。",
            "蝶散餘香在，莺啼半树空。堪悲一尊酒，从此似西东。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 12
    },
    {
        "title": "柳花寄宋明府",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "每爱江城里，青春向尽时。一回新雨歇，是处好风吹。",
            "破石黏虫网，高楼扑酒旗。遥知陶令宅，五树正离披。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 13
    },
    {
        "title": "送人",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "相见未逾月，堪悲远别离。非君谁顾我，万里又南之。",
            "雨逼清明日，花阴杜宇时。愁看挂帆处，鸥鸟共迟迟。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 14
    },
    {
        "title": "閒游",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "携酒复携觞，朝朝一似忙。马谙频到路，僧借旧眠床。",
            "道胜他图薄，身闲白日长。扁舟动归思，高处见沧浪。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 15
    },
    {
        "title": "柏梁隔句韵诗",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "不喜长亭柳，枝枝拟送君。惟怜北窗□，树树解留人。",
            "圆缺都如月，东西只似云。愁看离席散，归盖动行尘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 16
    },
    {
        "title": "赠赵学士",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "常钦赵夫子，远作五侯宾。见面到今日，操心如古人。",
            "醉同华席少，吟访野僧频。寂寂长河畔，荒斋与庙邻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 17
    },
    {
        "title": "春阴",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "老雨不肯休，东风势还作。未放草蒙茸，已遣花萧索。",
            "浮生何苦劳，触事妨行乐。寄语达生人，须知酒胜药。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 18
    },
    {
        "title": "春日金谷园",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "火急召亲宾，欢游莫厌频。日长徒似岁，花过即非春。",
            "晚雨来何定，东风自不匀。须知三个月，不是负芳晨。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 19
    },
    {
        "title": "夏日酬祥松二公见访",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "多谢空门客，时时出草堂。从容非有约，淡薄不相忘。",
            "池映春篁老，簷垂夏果香。西峰正清霁，自与拂吟床。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 20
    },
    {
        "title": "怀赠操禅师",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "尝忆曹溪子，龛居面碧嵩。杉松新夏后，雨雹夜禅中。",
            "道匪因经悟，心能向物空。秋来得音信，又在剡山东。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 21
    },
    {
        "title": "閒居秋思呈祥松二公",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "秋光虽即好，客思转悠哉。去国身将老，流年雁又来。",
            "叶红堆晚径，菊冷藉空罍。不得师相访，难将道自開。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 22
    },
    {
        "title": "赋得冬日青溪草堂四十字",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "莫道无幽致，常来到日西。地虽当北阙，天与设东溪。",
            "疏苇寒多折，惊凫去不齐。坐中皆作者，长爱觅分题。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 23
    },
    {
        "title": "溪斋",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "水木绕吾廬，搴帘晚槛虚。衰条寒露鹊，幽果落惊鱼。",
            "爱酒贫还甚，趋时老更疏。乖慵自有素，不是忽簪裾。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 24
    },
    {
        "title": "留题爱敬寺",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "野性竟未改，何以居朝廷。空为百官首，但爱千峰青。",
            "南风新雨后，与客携觞行。斜阳惜归去，万壑啼鸟声。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 25
    },
    {
        "title": "小园",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "小园吾所好，栽植忘劳形。晚果经秋赤，寒蔬近社青。",
            "竹萝荒引蔓，土井浅生萍。更欲从人劝，凭高置草亭。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 26
    },
    {
        "title": "宿山房",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "石窗灯欲尽，松槛月还明。就枕浑无睡，披衣却出行。",
            "岩高泉乱滴，林动鸟时惊。倏忽山钟曙，喧喧仆马声。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 27
    },
    {
        "title": "金陵所居青溪草堂闲兴",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "窗外皆连水，杉松欲作林。自怜趋竞地，独有爱閒心。",
            "素壁题看遍，危冠醉不簪。江僧暮相访，帘卷见秋岑。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 28
    },
    {
        "title": "阙下偶书寄孙员外",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "长安驱驰地，贵贱共悠悠。白日谁相促，劳生自不休。",
            "凤翔双阙晓，蝉噪六街秋。独有南宫客，时来话钓舟。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 29
    },
    {
        "title": "寄魏郎中",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "碌碌但随群，蒿兰任不分。未尝矜有道，求遇向吾君。",
            "逸驾秋寻寺，长歌醉望云。高斋纸屏古，尘暗北山文。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 30
    },
    {
        "title": "病中书怀寄王二十六",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "落叶满山州，闲眠病未瘳。窗阴连竹枕，药气染茶瓯。",
            "路匪人遮去，官须自觅休。焉宜更羸老，扶杖作公侯。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 31
    },
    {
        "title": "采菊",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "簇簇竟相鲜，一枝開几番。味甘资麹糵，香好胜兰荪。",
            "古道风摇远，荒篱露压繁。盈筐时采得，服饵近知门。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 32
    },
    {
        "title": "送王郎中之官吉水",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "南望廬陵郡，山连五岭长。吾君怜远俗，从事辍名郎。",
            "移户多无土，春蚕不满筐。惟应劳赞畫，溪峒况强梁。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 33
    },
    {
        "title": "孤雁",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "欲食不敢食，合栖犹未栖。闻风亦惊过，避缴恨飞低。",
            "水阔缘湘困，云寒过碛迷。悲鸣感人意，不见夜乌啼。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 34
    },
    {
        "title": "赠送致仕郎中",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "鹤立瘦棱棱，髭长白似银。衣冠皆古制，气貌异常人。",
            "听雪添诗思，看山滞酒巡。西峰重归路，唯许野僧亲。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 35
    },
    {
        "title": "宿友人山居寄司徒相公",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "雨雪正霏霏，令人不忆归。地炉僧坐暖，山枿火声肥。",
            "隔纸烘茶蕊，移铛剥芋衣。知君在霄汉，此兴得还稀。",
            "郢客相寻夜，荒庭雪洒篙。虚堂看向曙，吟坐共忘劳。",
            "溪冻声全减，灯寒焰不高。他人莫相笑，未易会吾曹。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 36
    },
    {
        "title": "感故府二首",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "戚戚复戚戚，期怀安可释。百年金石心，中路生死隔。",
            "新坟应草合，旧地空苔色。白日灯荧荧，凝尘满几席。",
            "悒悒复悒悒，思君安可及。永日在阶前，披衣随风立。",
            "高楼暮角断，远树寒鸦集。惆怅几行书，遗踪墨犹湿。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 37
    },
    {
        "title": "田家三首",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "毕岁知无事，兵销复旧丁。竹门桑径狭，春日稻畦青。",
            "犬吠隈篱落，鸡飞上碓桯。归田起囗思，蛙叫草冥冥。",
            "不识城中路，熙熙乐有年。木盘擎社酒，瓦鼓送神钱。",
            "霜落牛归屋，禾收雀满田。遥陂过秋水，闲阁钓鱼船。",
            "长爱田家事，时时欲一过。垣篱皆树槿，厅院亦堆禾。",
            "病果因风落，寒蔬向日多。遥闻数声笛，牛晚下前坡。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 38
    },
    {
        "title": "新竹",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "袅袅熏风软，娟娟湛露光。参差仙子仗，迤逦羽林枪。",
            "迥去侵花地，斜来破藓墙。箨干犹抱翠，粉腻若涂装。",
            "径曲茎难数，阴疏叶未长。懒嫌吟客倚，甘畏夏虫伤。",
            "映水如争立，当轩自著行。北亭尊酒兴，还为此君狂。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 39
    },
    {
        "title": "归燕词",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "羽翼势虽微，云霄亦可期。飞翻自有路，鸿鹄莫相嗤。",
            "待侣临书幌，寻泥傍藻池。冲人穿柳径，捕蝶绕花枝。",
            "广厦来应遍，深宫去不疑。雕梁声上下，烟浦影参差。",
            "旧地人潜换，新巢雀谩窥。双双暮归处，疏雨满江湄。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 40
    },
    {
        "title": "题魏坛二首",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "不遇至真传道要，曾看真诰亦何为。旧碑经乱沈荒涧，",
            "萧条夕景空坛畔，朽桧枝斜绿蔓垂。",
            "一寻遗迹到仙乡，云鹤沉沉思渺茫。丹井岁深生草木，",
            "薄暮欲归仍伫立，菖蒲风起水泱泱。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 41
    },
    {
        "title": "东楼看雪",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "一上高楼醉复醒，日西江雪更冥冥。化风吹火全无气，",
            "因思旧隐匡廬日，闲看杉柽掩石扃。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 42
    },
    {
        "title": "落花",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "惜花无计又花残，独绕芳丛不忍看。暖艳动随莺翅落，",
            "忍把一尊重命乐，送春招客亦何欢。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 43
    },
    {
        "title": "春雪",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "南国春寒朔气回，霏霏还阻百花開。全移暖律何方去，",
            "不知金勒谁家子，只待晴明赏帝台。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 44
    },
    {
        "title": "重戏和春雪寄沈员外",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "谁道江南要雪难，半春犹得倚楼看。却遮迟日偷莺暖，",
            "和来琼什虽无敌，且是侬家比兴残。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 45
    },
    {
        "title": "春日尊前示从事",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "州中案牍鱼鳞密，界上军书竹节稠。眼底好花浑似雪，",
            "最觉此春无气味，不如庭草解忘忧。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 46
    },
    {
        "title": "尊前",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "官为将相复何求，世路多端早合休。渐老更知春可惜，",
            "莫厌百壶相劝倒，免教无事结閒愁。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 47
    },
    {
        "title": "蔷薇二首",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "万蕊争開照槛光，诗家何物可相方。锦江风撼云霞碎，",
            "彩笺蛮榼旬休日，欲召亲宾看一场。",
            "拂簷拖地对前墀，蝶影蜂声烂熳时。万倍馨香胜玉蕊，",
            "将并舞腰谁得及，惹衣伤手尽从伊。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 48
    },
    {
        "title": "残牡丹",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "肠断题诗如执别，芳茵愁更绕阑铺。风飘金蕊看全落，",
            "回看池馆春休也，又是迢迢看畫图。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 49
    },
    {
        "title": "春雨二首",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "春霖未免妨游赏，唯到诗家自有情。花径不通新草合，",
            "闲忆昔年为客处，闷留山馆阻行行。",
            "萧萧春雨密还疏，景象三时固不如，寒入远林莺翅重，",
            "唯称乖慵多睡者，掩门中酒览閒书。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 50
    },
    {
        "title": "醉中惜花更书与诸从事",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "公退寻芳已是迟，莫因他事更来稀。未经旬日唯忧落，",
            "高楼鼓绝重门闭，长为抛回恨解衣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 51
    },
    {
        "title": "和判官喜雨",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "去祷山川尚未还，云雷寻作远声寒。人情便似秋登悦，",
            "须知太守重墙内，心极农夫望处欢。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 52
    },
    {
        "title": "离阙下日感恩",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "二年尘冒处中台，喜得南归退不才。即路敢期皇子送，",
            "斜日苇汀凝立处，远波微飏翠如苔。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 53
    },
    {
        "title": "细雨遥怀故人",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "江云未散东风暖，溟蒙正在高楼见。细柳缘堤少过人，",
            "昨夜南窗不得眠，闲阶点滴回灯坐。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 54
    },
    {
        "title": "春水",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "万派争流雨过时，晚来春静更逶迤。轻鸥散绕夫差国，",
            "风鬟倚楫谁家子，愁看鸳鸯望所之。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 55
    },
    {
        "title": "蝶",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "粉蝶翩翩若有期，南园长是到春归。闲依柳带参差起，",
            "晚来欲雨东风急，回看池塘影渐稀。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 56
    },
    {
        "title": "中春写怀寄沈彬员外",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "省从骑竹学讴吟，便𣨼光阴役此心。寓目不能闲一日，",
            "唯有故人同此兴，近来何事懒相寻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 57
    },
    {
        "title": "钟山寺避暑勉二三子",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "楼台虽少景何深，满地青苔胜布金。松影晚留僧共坐，",
            "长爱寄吟经案上，石窗秋霁向千岑。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 58
    },
    {
        "title": "道林寺",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "虽向钟峰数寺连，就中奇胜出其间。不教幽树妨闲地，",
            "无因得结香灯社，空向王门玷玉班。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 59
    },
    {
        "title": "和致仕沈郎中",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "欲谋休退尚因循，且向东溪种白蘋。谬应星辰居四辅，",
            "残照晚庭沈醉醒，静吟斜倚老松身。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 60
    },
    {
        "title": "醉中咏梅花",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "十月清霜尚未寒，雪英重叠已如抟。还悲独咏东园里，",
            "交亲罕至长安远，一醉如泥岂自欢。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 61
    },
    {
        "title": "闲出书怀",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "閒游何用问东西，寓兴皆非有所期。断酒只携僧共去，",
            "应有交亲长笑我，独轻人事鬓将衰。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 62
    },
    {
        "title": "寺居陆处士相访，感怀却寄二三友人",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "湘寺閒居亦半年，就中昨夜好潸然。人归远岫疏钟后，",
            "炉烟向冷孤灯下，唯有寒吟到曙天。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 63
    },
    {
        "title": "春雪",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "随风竟日势漫漫，特地繁於故岁看。幽榭冻黏花屋重，",
            "莫道便为桑麦药，亦胜焦涸到春残。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 64
    },
    {
        "title": "惜花",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "淡淡西园日又垂，一尊何忍负芳枝。莫言风雨长相促，",
            "年年使我成狂叟，肠断红笺几首诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 65
    },
    {
        "title": "梅花寄所亲",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "一气才新物未知，每惭青律与先吹。雪霜迷素犹嫌早，",
            "老夫多病无风味，只向尊前咏旧诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 66
    },
    {
        "title": "登升元阁",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "登高始觉太虚宽，白雪须知唱和难。云渡琐窗金榜湿，",
            "唯有上层人未到，金乌飞过拂阑干。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 67
    },
    {
        "title": "雪有作",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "霏霏奕奕满寒空，况是难逢值腊中。未白已堪张宴会，",
            "长爱清华入诗句，预愁迟日放消融。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 68
    },
    {
        "title": "宫词",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "自远凝旒守上阳，舞衣顿减旧朝香。帘垂粉阁春将尽，",
            "君王一去不回驾，皓齿青蛾空断肠。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 69
    },
    {
        "title": "晚春送牡丹",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "携觞邀客绕朱阑，肠断残春送牡丹。风雨数来留不得，",
            "借问少年能几许，不许推酒厌杯盘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 70
    },
    {
        "title": "岁暮晚泊，望廬山不见，因怀岳僧呈察判",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "贪程只为看廬阜，及到停舟恨颇浓。云暗半空藏万仞，",
            "长愧昔年招我入，共寻香社见芙蓉。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 71
    },
    {
        "title": "重台莲",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "斜倚秋风绝比伦，千英和露染难匀。自为祥瑞生南国，",
            "怜伊不算多时立，赢得馨香暗上身。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 72
    },
    {
        "title": "迎神",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "攂蛮鼍，吟塞笛，女巫结束分行立。空中再拜神且来，",
            "与君降福为丰年，莫教赛祀亏常筵。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 73
    },
    {
        "title": "春词",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "日高閒步下堂阶，细草春莎没绣鞋。",
            "折得玫瑰花一朵，凭君簪向凤凰钗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 74
    },
    {
        "title": "独夜作",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "佳人一去无消息，梦觉香残愁复入。",
            "空庭悄悄月如霜，独倚阑干伴花立。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 75
    },
    {
        "title": "竹",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "琼节高吹宿凤枝，风流交我立忘归。",
            "最怜瑟瑟斜阳下，花影相和满客衣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 76
    },
    {
        "title": "清明日",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "他皆携酒寻芳去，我独关门好静眠。",
            "唯有杨花似相觅，因风时复到床前。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 77
    },
    {
        "title": "宫词",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "宫门长闭舞衣闲，略识君王鬓便斑。",
            "却羡落花春不管，御沟流得到人间。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 78
    },
    {
        "title": "送喻炼师归茅山",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "休粮知几载，脸色似桃红。半醉离城去，单衣行雪中。",
            "水声茅洞晓，云影石房空。莫学秦时客，音书便不通。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 79
    },
    {
        "title": "和元宗元日大雪登楼",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "纷纷忽降当元会，著物轻明似月华。狂洒玉墀初散絮，",
            "宁意传来中使出，御题先赐老僧家。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 80
    },
    {
        "title": "游栖霞寺",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "养花天气近平分，瘦马来敲白下门。晓色未開山意远，",
            "此地几经人聚散，只今王谢独名存。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 81
    },
    {
        "title": "答汤悦",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "司空犹不作，那敢作司徒。幸有山翁号，如何不见呼。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 82
    },
    {
        "title": "金山",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "不嗟白发曾游此，不叹征帆无了期。",
            "尽日凭阑谁会我，只悲不见韩垂诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 83
    },
    {
        "title": "送李冠",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "匀如春涧长流水，怨似秋枝欲断蝉。",
            "可惜人间容易听，清声不到御楼前。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 84
    },
    {
        "title": "游宋兴寺东岩",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "几年不到东岩下，旧住僧亡屋亦无。",
            "寒日萧条何物在，朽松经烧石池枯。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 85
    },
    {
        "title": "批周宗书后",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "偶罢阿衡来典郡，固无闲物可应官。",
            "凭君为报群胥道，莫作循州刺史看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷七百三十九",
        "no#": 86
    },
    {
        "title": "题信果观壁",
        "author": "李建勋",
        "biography": "",
        "paragraphs": [
            "春来涨水流而活，晓色西山势似行。",
            "玉洞主人经劫在，携竿步步就长生。"
        ],
        "notes": [
            ""
