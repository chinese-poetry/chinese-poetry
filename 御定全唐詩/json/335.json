[
    {
        "title": "享惠昭太子庙乐章",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "重轮始发祥，齿胄方兴学。冥然升紫府，铿尔荐清乐。",
            "奠斝致馨香，在庭纷羽钥。礼成神既醉，仿佛缑山鹤。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 1
    },
    {
        "title": "夏日对雨",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "登楼逃盛夏，万象正埃尘。对面雷嗔树，当街雨趁人。",
            "簷疏蛛网重，地湿燕泥新。吟罢清风起，荷香满四邻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 2
    },
    {
        "title": "白二十二侍郎有双鹤留在洛下予西园多野水长松可以栖息遂以诗请之",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "闻君有双鹤，羁旅洛城东。未放归仙去，何如乞老翁。",
            "且将临野水，莫闭在樊笼。好是长鸣处，西园白露中。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 3
    },
    {
        "title": "窦七中丞见示初至夏口献元戎诗，辄戏和之",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "出佐青油幕，来吟白雪篇。须为九皋鹤，莫上五湖船。",
            "故态君应在，新诗我亦便。元侯看再入，好被暂流连。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 4
    },
    {
        "title": "酬张秘书因寄马赠诗",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "满城驰逐皆求马，古寺闲行独与君。代步本惭非逸足，",
            "飞控著鞭能顾我，当时王粲亦从军。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 5
    },
    {
        "title": "真慧寺",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "遍寻真迹蹑莓苔，世事全抛不忍回。上界不知何处去，",
            "更有一般人不见，白莲花向半天開。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 6
    },
    {
        "title": "中书即事",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "有意效承平，无功答圣明。灰心缘忍事，霜鬓为论兵。",
            "道直身还在，恩深命转轻。盐梅非拟议，葵藿是平生。",
            "白日长悬照，苍蝇谩发声。高阳旧田里，终使谢归耕。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 7
    },
    {
        "title": "中和节诏赐公卿尺",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "阳和行庆赐，尺度及群公。荷宠承佳节，倾心立大中。",
            "短长思合制，远近贵攸同。共仰财成德，将酬分寸功。",
            "作程施有政，垂范播无穷。願续南山寿，千春奉圣躬。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 8
    },
    {
        "title": "至日登乐游园",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "阴律随寒改，阳和应节生。祥云观魏阙，瑞气映秦城。",
            "验炭论时政，书云受岁盈。晷移长日至，雾敛远霄清。",
            "景暖仙梅动，风柔御柳倾。那堪封得意，空对物华情。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 9
    },
    {
        "title": "奉酬中书相公至日圆丘摄事合於中书后阁宿斋移止於集贤院叙怀见寄之作",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "翼亮登三命，谟猷本一心。致斋移秘府，祗事见冲襟。",
            "皓月当延阁，祥风自禁林。相庭方积玉，王度已如金。",
            "运偶唐虞盛，情同丙魏深。幽兰与白雪，何处寄庸音。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 10
    },
    {
        "title": "太原题厅壁",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "危事经非一，浮荣得是空。白头官舍里，今日又春风。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 11
    },
    {
        "title": "溪居",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "门径俯清溪，茅簷古木齐。红尘飘不到，时有水禽啼。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 12
    },
    {
        "title": "喜遇刘二十八",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "病来佳兴少，老去旧游稀。笑语纵横作，杯觞络绎飞。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 13
    },
    {
        "title": "送刘",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "不归丹掖去，铜竹漫云云。惟喜因过我，须知未贺君。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 14
    },
    {
        "title": "再送",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "顷来多谑浪，此夕任喧纷。故态犹应在，行期未要闻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 15
    },
    {
        "title": "凉风亭睡觉",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "饱食缓行新睡觉，一瓯新茗侍儿煎。",
            "脱巾斜倚绳床坐，风送水声来耳边。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 16
    },
    {
        "title": "雪中讶诸公不相访",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "忆昨雨多泥又深，犹能携妓远过寻。",
            "满空乱雪花相似，何事居然无赏心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 17
    },
    {
        "title": "傍水闲行",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "闲餘何处觉身轻，暂脱朝衣傍水行。",
            "鸥鸟亦知人意静，故来相近不相惊。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 18
    },
    {
        "title": "句",
        "author": "裴度",
        "biography": "",
        "paragraphs": [
            "两人同日事征西，今日君先奉紫泥。",
            "待平贼垒报天子，莫指仙山示武夫。",
            "野人不识中书令，唤作陶家与谢家。。",
            "君若有心求逸足，我还留意在名姝。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百三十五",
        "no#": 19
    }
]