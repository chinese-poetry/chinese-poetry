[
    {
        "title": "古离别",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "下阶欲离别，相对映兰丛。含辞未及吐，泪落兰丛中。",
            "高堂静秋日，罗衣飘暮风。谁能待明月，回首见床空。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 1
    },
    {
        "title": "青雀歌",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "林间青雀儿，来往翩翩绕一枝。",
            "莫言不解衔环报，但问君恩今若为。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 2
    },
    {
        "title": "同王昌龄裴迪游青龙寺昙壁上人兄院集和兄维",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "林中空寂舍，阶下终南山。高卧一床上，回看六合间。",
            "浮云几处灭，飞鸟何时还。问义天人接，无心世界闲。",
            "谁知大隐者，兄弟自追攀。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 3
    },
    {
        "title": "别辋川别业",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "山月晓仍在，林风凉不绝。殷勤如有情，惆怅令人别。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 4
    },
    {
        "title": "与卢员外象过崔处士兴宗林亭",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "身名不问十年餘，老大谁能更读书。",
            "林中独酌邻家酒，门外时闻长者车。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 5
    },
    {
        "title": "九日作",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "莫将边地比京都，八月严霜草已枯。",
            "今日登高樽酒里，不知能有菊花无。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 6
    },
    {
        "title": "送孙秀才",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "帝城风日好，况复建平家。玉枕双纹簟，金盘五色瓜。",
            "山中无鲁酒，松下饭胡麻。莫厌田家苦，归期远复赊。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 7
    },
    {
        "title": "游悟真寺",
        "author": "王缙",
        "biography": "",
        "paragraphs": [
            "闻道黄金地，仍開白玉田。掷山移巨石，咒岭出飞泉。",
            "猛虎同三径，愁猿学四禅。買香然绿桂，乞火蹈红莲。",
            "草色摇霞上，松声泛月边。山河穷百二，世界接三千。",
            "梵宇聊凭视，王城遂渺然。灞陵才出树，渭水欲连天。",
            "远县分朱郭，孤村起白烟。望云思圣主，披雾忆群贤。",
            "薄宦惭尸素，终身拟尚玄。谁知草庵客，曾和柏梁篇。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 8
    },
    {
        "title": "青龙寺昙壁上人院集",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "灵境信为绝，法堂出尘氛。自然成高致，向下看浮云。",
            "迤逦峰岫列，参差闾井分。林端远堞见，风末疏钟闻。",
            "吾师久禅寂，在世超人群。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 9
    },
    {
        "title": "青雀歌",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "动息自适性，不曾妄与燕雀群。幸忝鹓鸾早相识，"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 10
    },
    {
        "title": "游感化寺昙兴上人山院",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "不远灞陵边，安居向十年。入门穿竹径，留客听山泉。",
            "鸟啭深林里，心闲落照前。浮名竟何益，从此願栖禅。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 11
    },
    {
        "title": "夏日过青龙寺谒操禅师",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "安禅一室内，左右竹亭幽。有法知不染，无言谁敢酬。",
            "鸟飞争向夕，蝉噪已先秋。烦暑自兹适，清凉何所求。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 12
    },
    {
        "title": "春日与王右丞过新昌里访吕逸人不遇",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "恨不逢君出荷蓑，青松白屋更无他。陶令五男曾不有，",
            "闻说桃源好迷客，不如高卧眄庭柯。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 13
    },
    {
        "title": "辋川集二十首：孟城坳",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "结廬古城下，时登古城上。古城非畴昔，今人自来往。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 14
    },
    {
        "title": "辋川集二十首：华子冈",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "落日松风起，还家草露晞。云光侵履迹，山翠拂人衣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 15
    },
    {
        "title": "辋川集二十首：文杏馆",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "迢迢文杏馆，跻攀日已屡。南岭与北湖，前看复回顾。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 16
    },
    {
        "title": "辋川集二十首：斤竹岭",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "明流纡且直，绿筱密复深。一径通山路，行歌望旧岑。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 17
    },
    {
        "title": "辋川集二十首：鹿柴",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "日夕见寒山，便为独往客。不知深林事，但有麏麚迹。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 18
    },
    {
        "title": "辋川集二十首：木兰柴",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "苍苍落日时，鸟声乱溪水。缘溪路转深，幽兴何时已。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 19
    },
    {
        "title": "辋川集二十首：茱萸沜",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "飘香乱椒桂，布叶间檀栾。云日虽回照，森沉犹自寒。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 20
    },
    {
        "title": "辋川集二十首：宫槐陌",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "门前宫槐陌，是向欹湖道。秋来山雨多，落叶无人扫。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 21
    },
    {
        "title": "辋川集二十首：临湖亭",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "当轩弥滉漾，孤月正裴回。谷口猿声发，风传入户来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 22
    },
    {
        "title": "辋川集二十首：南垞",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "孤舟信一泊，南垞湖水岸。落日下崦嵫，清波殊淼漫。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 23
    },
    {
        "title": "辋川集二十首：欹湖",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "空阔湖水广，青荧天色同。舣舟一长啸，四面来清风。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 24
    },
    {
        "title": "辋川集二十首：柳浪",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "映池同一色，逐吹散如丝。结阴既得地，何谢陶家时。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 25
    },
    {
        "title": "辋川集二十首：栾家濑",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "濑声喧极浦，沿涉向南津。泛泛鸥凫渡，时时欲近人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 26
    },
    {
        "title": "辋川集二十首：金屑泉",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "萦渟澹不流，金碧如可拾。迎晨含素华，独往事朝汲。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 27
    },
    {
        "title": "辋川集二十首：白石滩",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "跂石复临水，弄波情未极。日下川上寒，浮云澹无色。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 28
    },
    {
        "title": "辋川集二十首：北垞",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "南山北垞下，结宇临欹湖。每欲采樵去，扁舟出菰蒲。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 29
    },
    {
        "title": "辋川集二十首：竹里馆",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "来过竹里馆，日与道相亲。出入唯山鸟，幽深无世人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 30
    },
    {
        "title": "辋川集二十首：辛夷坞",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "绿堤春草合，王孙自留玩。况有辛夷花，色与芙蓉乱。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 31
    },
    {
        "title": "辋川集二十首：漆园",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "好闲早成性，果此谐宿诺。今日漆园游，还同庄叟乐。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 32
    },
    {
        "title": "辋川集二十首：椒园",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "丹刺罥人衣，芳香留过客。幸堪调鼎用，願君垂采摘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 33
    },
    {
        "title": "辋口遇雨忆终南山因献王维",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "积雨晦空曲，平沙灭浮彩。辋水去悠悠，南山复何在。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 34
    },
    {
        "title": "崔九欲往南山马上口号与别",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "归山深浅去，须尽丘壑美。莫学武陵人，暂游桃源里。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 35
    },
    {
        "title": "与卢员外象过崔处士兴宗林亭",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "乔柯门里自成阴，散发窗中曾不簪。",
            "逍遥且喜从吾事，荣宠从来非我心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 36
    },
    {
        "title": "西塔寺陆羽茶泉",
        "author": "裴迪",
        "biography": "",
        "paragraphs": [
            "竟陵西塔寺，踪迹尚空虚。不独支公住，曾经陆羽居。",
            "草堂荒产蛤，茶井冷生鱼。一汲清泠水，高风味有餘。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 37
    },
    {
        "title": "同王右丞送瑗公南归",
        "author": "崔兴宗",
        "biography": "",
        "paragraphs": [
            "行苦神亦秀，泠然溪上松。铜瓶与竹杖，来自祝融峰。",
            "常願入灵岳，藏经访遗踪。南归见长老，且为说心胸。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 38
    },
    {
        "title": "青雀歌",
        "author": "崔兴宗",
        "biography": "",
        "paragraphs": [
            "青扈绕青林，翩翾陋体一微禽。",
            "不应常在藩篱下，他日凌云谁见心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 39
    },
    {
        "title": "和王维敕赐百官樱桃",
        "author": "崔兴宗",
        "biography": "",
        "paragraphs": [
            "未央朝谒正逶迤，天上樱桃锡此时。朱实初传九华殿，",
            "闻道令人好颜色，神农本草自应知。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 40
    },
    {
        "title": "留别王维",
        "author": "崔兴宗",
        "biography": "",
        "paragraphs": [
            "驻马欲分襟，清寒御沟上。前山景气佳，独往还惆怅。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 41
    },
    {
        "title": "酬王维卢象见过林亭",
        "author": "崔兴宗",
        "biography": "",
        "paragraphs": [
            "穷巷空林常闭关，悠然独卧对前山。",
            "今朝忽枉嵇生驾，倒屣開门遥解颜。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 42
    },
    {
        "title": "送大理正摄御史判凉州别驾",
        "author": "苑咸",
        "biography": "",
        "paragraphs": [
            "天子念西疆，咨君去不遑。垂银棘庭印，持斧柏台纲。",
            "雪下天山白，泉枯塞草黄。伫闻河陇外，还继海沂康。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 43
    },
    {
        "title": "酬王维",
        "author": "苑咸",
        "biography": "",
        "paragraphs": [
            "莲花梵字本从天，华省仙郎早悟禅。三点成伊犹有想，",
            "应同罗汉无名欲，故作冯唐老岁年。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 44
    },
    {
        "title": "寻西山隐者不遇",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "绝顶一茅茨，直上三十里。扣关无僮仆，窥室唯案几。",
            "若非巾柴车，应是钓秋水。差池不相见，黾勉空仰止。",
            "草色新雨中，松声晚窗里。及兹契幽绝，自足荡心耳。",
            "虽无宾主意，颇得清净理。兴尽方下山，何必待之子。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 45
    },
    {
        "title": "题农父廬舍",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "东风何时至，已绿湖上山。湖上春已早，田家日不闲。",
            "沟塍流水处，耒耜平芜间。薄暮饭牛罢，归来还闭关。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 46
    },
    {
        "title": "泛若耶溪",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "结廬若耶里，左右若耶水。无日不钓鱼，有时向城市。",
            "溪中水流急，渡口水流宽。每得樵风便，往来殊不难。",
            "一川草长绿，四时那得辨。短褐衣妻儿，餘粮及鸡犬。",
            "日暮鸟雀稀，稚子呼牛归。住处无邻里，柴门独掩扉。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 47
    },
    {
        "title": "湖中寄王侍御",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "日日湖水上，好登湖上楼。终年不向郭，过午始梳头。",
            "尝自爱杯酒，得无相献酬。小僮能脍鲤，少妾事莲舟。",
            "每有南浦信，仍期后月游。方春转摇荡，孤兴时淹留。",
            "驄马真傲吏，翛然无所求。晨趋玉阶下，心许沧江流。",
            "少别如昨日，何言经数秋。应知方外事，独往非悠悠。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 48
    },
    {
        "title": "登润州城",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "天末江城晚，登临客望迷。春潮平岛屿，残雨隔虹蜺。",
            "鸟与孤帆远，烟和独树低。乡山何处是，目断广陵西。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 49
    },
    {
        "title": "寻廬山崔征君",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "日高鸡犬静，门掩向寒塘。夜竹深茅宇，秋亭冷石床。",
            "住山年已远，服药寿偏长。虚弃浮生者，相逢益自伤。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 50
    },
    {
        "title": "留别王维",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "归鞍白云外，缭绕出前山。今日又明日，自知心不闲。",
            "亲劳簪组送，欲趁莺花还。一步一回首，迟迟向近关。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 51
    },
    {
        "title": "竹下残雪",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "一点消未尽，孤月在竹阴。晴光夜转莹，寒气晓仍深。",
            "还对读书牖，且关乘兴心。已能依此地，终不傍瑶琴。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 52
    },
    {
        "title": "送阎校书之越",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "南入剡中路，草云应转微。湖边好花照，山口细泉飞。",
            "此地饶古迹，世人多忘归。经年松雪在，永日世情稀。",
            "芸阁应相望，芳时不可违。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 53
    },
    {
        "title": "省试夏日可畏",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "赫赫温风扇，炎炎夏日徂。火威驰迥野，畏景烁遥途。",
            "势矫翔阳翰，功分造化炉。禁城千品烛，黄道一轮孤。",
            "落照频空簟，餘晖卷夕梧。如何倦游子，中路独踟蹰。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 54
    },
    {
        "title": "左掖梨花",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "冷艳全欺雪，餘香乍入衣。春风且莫定，吹向玉阶飞。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 55
    },
    {
        "title": "渡汉江",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "漾舟汉江上，挂席候风生。临泛何容与，爱此江水清。",
            "芦洲隐遥嶂，露日映孤城。自顾疏野性，难忘鸥鸟情。",
            "聊复与时顾，暂欲解尘缨。跋涉非吾願，虚怀浩已盈。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 56
    },
    {
        "title": "冬至下寄舍弟时应赴入京",
        "author": "丘为",
        "biography": "",
        "paragraphs": [
            "去去知未远，依依甚初别。他乡至下心，昨夜阶前雪。",
            "终日读书仍少孤，家贫兄弟未当途。适远才过宿舂料，",
            "莫漫忆柴扉，驷马高车朝紫微。江南驿使不曾断，"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 57
    },
    {
        "title": "送晁补阙归日本国",
        "author": "赵骅",
        "biography": "",
        "paragraphs": [
            "西掖承休浣，东隅返故林。来称郯子学，归是越人吟。",
            "马上秋郊远，舟中曙海阴。知君怀魏阙，万里独摇心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷一百二十九",
        "no#": 58
    }
]