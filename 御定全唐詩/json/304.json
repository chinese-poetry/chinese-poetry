[
    {
        "title": "怨妇",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "净扫黄金阶，飞霜皎如雪。下帘弹箜篌，不忍见秋月。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 1
    },
    {
        "title": "绿珠怨",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "从来上台榭，不敢倚阑干。零落知成血，高楼直下看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 2
    },
    {
        "title": "古意",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "达晓寝衣冷，開帷霜露凝。风吹昨夜泪，一片枕前冰。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 3
    },
    {
        "title": "哭萧抡",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "何处哭故人，青门水如箭。当时水头别，从此不相见。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 4
    },
    {
        "title": "送从弟赴上都",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "车骑秦城远，囊装楚客贫。月明思远道，诗罢诉何人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 5
    },
    {
        "title": "登相国寺阁",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "晴日登临好，春风各望家。垂杨夹城路，客思逐杨花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 6
    },
    {
        "title": "酬浚上人采药见寄",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "玉英期共采，云岭独先过。应得灵芝也，诗情一倍多。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 7
    },
    {
        "title": "曲水寺枳实",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "枳实绕僧房，攀枝置药囊。洞庭山上橘，霜落也应黄。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 8
    },
    {
        "title": "酬问师",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "虚空无处所，仿佛似琉璃。诗境何人到，禅心又过诗。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 9
    },
    {
        "title": "殷秀才求诗",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "倾盖见芳姿，晴天琼树枝。连城犹隐石，唯有卞和知。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 10
    },
    {
        "title": "行营即事",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "万姓厌干戈，三边尚未和。将军夸宝剑，功在杀人多。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 11
    },
    {
        "title": "送刘寰北归",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "南巢登望县城孤，半是青山半是湖。",
            "知尔素多山水兴，此回归去更来无。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 12
    },
    {
        "title": "送王闬归苏州",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "深山穷谷没人来，邂逅相逢眼渐開。",
            "云鹤洞宫君未到，夕阳帆影几时回。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 13
    },
    {
        "title": "送人往虔州",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "莫叹乘轺道路赊，高楼日日望还家。",
            "人到南康皆下泪，唯君笑向此中花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 14
    },
    {
        "title": "送僧往湖南",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "闲出东林日影斜，稻苗深浅映袈裟。",
            "船到南湖风浪静，可怜秋水照莲花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 15
    },
    {
        "title": "送元使君自楚移越",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "露冕行春向若耶，野人怀惠欲移家。",
            "东风二月淮阴郡，唯见棠梨一树花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 16
    },
    {
        "title": "移居深山谢别亲故",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "不食黄精不采薇，葛苗为带草为衣。",
            "孤云更入深山去，人绝音书雁自飞。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 17
    },
    {
        "title": "送王永二首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "君去春山谁共游，鸟啼花落水空流。",
            "如今送别临溪水，他日相思来水头。",
            "绵衣似热夹衣寒，时景虽和春已阑。",
            "诚知暂别那惆怅，明日藤花独自看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 18
    },
    {
        "title": "送别",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "灞岸青门有弊廬，昨来闻道半丘墟。",
            "陌头空送长安使，旧里无人可寄书。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 19
    },
    {
        "title": "送王贞",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "清阳玉润复多才，邂逅佳期过早梅。",
            "槿花亦可浮杯上，莫待东篱黄菊開。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 20
    },
    {
        "title": "送薛六暂游扬州",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "志在乘轩鸣玉珂，心期未快隐青萝。",
            "广陵行路风尘合，城郭新秋砧杵多。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 21
    },
    {
        "title": "送杨行元赴举",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "晚渡邗沟惜别离，渐看烽火马行迟。",
            "千钧何处穿杨叶，二月长安折桂枝。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 22
    },
    {
        "title": "行营送人",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "鞞鼓喧喧对古城，独寻归鸟马蹄轻。",
            "回来看觅莺飞处，即是将军细柳营。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 23
    },
    {
        "title": "滑州送人先归",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "河水冰消雁北飞，寒衣未足又春衣。",
            "自怜漂荡经年客，送别千回独未归。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 24
    },
    {
        "title": "送浚上人",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "木落前山霜露多，手持寒锡远头陀。",
            "眼看庭树梅花发，不见诗人独咏歌。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 25
    },
    {
        "title": "高邮送弟遇北游",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "门临楚国舟船路，易见行人易别离。",
            "今日送君心最恨，孤帆水下又风吹。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 26
    },
    {
        "title": "送豆卢郎赴海陵",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "烟波极目已沾襟，路出东塘水更深。",
            "看取海头秋草色，一如江上别离心。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 27
    },
    {
        "title": "送女子",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "青娥宛宛聚为裳，乌鹊桥成别恨长。",
            "惆怅梧桐非旧影，不悲鸿雁暂随阳。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 28
    },
    {
        "title": "酬道芬寄畫松",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "闻道铅华学沈宁，寒枝淅沥叶青青。",
            "一株将比囊中树，若个年多有茯苓。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 29
    },
    {
        "title": "山翁持酒相访以畫松酬之",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "白社风霜惊暮年，铜瓶桑落慰秋天。",
            "怜君意厚留新畫，不著松枝当酒钱。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 30
    },
    {
        "title": "题潘师房",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "渡水傍山寻石壁，白云飞处洞门開。",
            "仙人来往行无迹，石径春风长绿苔。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 31
    },
    {
        "title": "谢自然却还旧居",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "仙侣招邀自有期，九天升降五云随。",
            "不知辞罢虚皇日，更向人间住几时。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 32
    },
    {
        "title": "寄李俌",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "挂却衣冠披薜荔，世人应是笑狂愚。",
            "年来渐觉髭须黑，欲寄松花君用无。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 33
    },
    {
        "title": "赠头陀师",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "少壮从戎马上飞，雪山童子未缁衣。",
            "秋山年长头陀处，说我军前射虎归。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 34
    },
    {
        "title": "赠严四草屦",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "轻微菅蒯将何用，容足偷安事颇同。",
            "日入信陵宾馆静，赠君閒步月明中。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 35
    },
    {
        "title": "题刘偃庄",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "何事退耕沧海畔，闲看富贵白云飞。",
            "门前种稻三回熟，县里官人四考归。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 36
    },
    {
        "title": "题黄陂夫人祠",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "苍山云雨逐明神，唯有香名万岁春。",
            "东风三月黄陂水，只见桃花不见人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 37
    },
    {
        "title": "题道济上人房",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "何处营求出世间，心中无事即身闲。",
            "门外水流风叶落，唯将定性对前山。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 38
    },
    {
        "title": "梨树阴",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "福庭人静少攀援，雨露偏滋影易繁。",
            "磊落紫香香亚树，清阴满地昼当轩。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 39
    },
    {
        "title": "秋蝉声",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "萧条旅舍客心惊，断续僧房静又清。",
            "借问蝉声何所为，人家古寺两般声。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 40
    },
    {
        "title": "归山留别子侄二首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "车马驱驰人在世，东西南北鹤随云。",
            "莫言贫病无留别，百代簪缨将付君。",
            "不逐浮云不羡鱼，杏花茅屋向阳居。",
            "鹤鸣华表应传语，雁度霜天懒寄书。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 41
    },
    {
        "title": "与湛上人院畫松",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "水墨乍成岩下树，摧残半隐洞中云。",
            "猷公曾住天台寺，阴雨猿声何处闻。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 42
    },
    {
        "title": "白沙宿窦常宅观妓",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "扬子澄江映晚霞，柳条垂岸一千家。",
            "主人留客江边宿，十月繁霜见杏花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 43
    },
    {
        "title": "上巳日两县寮友会集时主邮不遂驰赴辄题以寄方寸",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "踏青看竹共佳期，春水晴山祓禊词。",
            "独坐邮亭心欲醉，樱桃落尽暮愁时。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 44
    },
    {
        "title": "怀张璪",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "苔石苍苍临涧水，阴风袅袅动松枝。",
            "世间唯有张通会，流向衡阳那得知。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 45
    },
    {
        "title": "与於中丞",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "万顷荒林不敢看，買山容足拟求安。",
            "田园失计全芜没，何处春风种蕙兰。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 46
    },
    {
        "title": "袁十五远访山门",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "僻居谋道不谋身，避病桃源不避秦。",
            "远入青山何所见，寒花满径白头人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 47
    },
    {
        "title": "行营病中",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "心许征南破虏归，可言羸病卧戎衣。",
            "迟迟不见怜弓箭，惆怅秋鸿敢近飞。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 48
    },
    {
        "title": "合溪水涨寄敬山人",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "共爱碧溪临水住，相思来往践莓苔。",
            "而今却欲嫌溪水，雨涨春流隔往来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 49
    },
    {
        "title": "不羡花",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "惆怅朝阳午又斜，剩栽桃李学仙家。",
            "花開花落人如旧，谁道容颜不及花。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 50
    },
    {
        "title": "醉后",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "春草秋风老此身，一瓢长醉任家贫。",
            "醒来还爱浮萍草，漂寄官河不属人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 51
    },
    {
        "title": "题水洞二首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "桃花流出武陵洞，梦想仙家云树春。",
            "今看水入洞中去，却是桃花源里人。",
            "长看岩穴泉流出，忽听悬泉入洞声。",
            "莫摘山花抛水上，花浮出洞世人惊。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 52
    },
    {
        "title": "代人村中悼亡二首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "花落茅簷转寂寥，魂随暮雨此中销。",
            "迩来庭柳无人折，长得垂枝一万条。",
            "虚室无人乳燕飞，苍苔满地履痕稀。",
            "庭前唯有蔷薇在，花似残妆叶似衣。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 53
    },
    {
        "title": "观猎三首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "梦非熊虎数年间，驱尽豺狼宇宙闲。",
            "传道单于闻校猎，相期不敢过阴山。",
            "日隐寒山猎未归，鸣弦落羽雪霏霏。",
            "梁园射尽南飞雁，淮楚人惊阳鸟啼。",
            "松月东轩许独游，深恩未报复淹留。",
            "梁园日暮从公猎，每过青山不举头。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 54
    },
    {
        "title": "畫石",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "苍藓千年粉绘传，坚贞一片色犹全。",
            "那知忽遇非常用，不把分铢补上天。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 55
    },
    {
        "title": "咏双開莲花",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "菡萏新花晓并開，浓妆美笑面相隈。",
            "西方采畫迦陵鸟，早晚双飞池上来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 56
    },
    {
        "title": "夜闻邻管",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "何事霜天月满空，鹂雏百啭向春风。",
            "邻家思妇更长短，杨柳如丝在管中。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 57
    },
    {
        "title": "山中寄元二侍御二首",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "心期汗漫卧云扃，家计漂零水上萍。",
            "桃李向秋凋落尽，一枝松色独青青。",
            "拖紫锵金济世才，知君倚玉望三台。",
            "深山穷谷无人到，唯有狂愚独自来。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 58
    },
    {
        "title": "上崔十五老丈",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "天汉乘槎可问津，寂寥深景到无因。",
            "看花独往寻诗客，不为经时谒丈人。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 59
    },
    {
        "title": "袁德师求畫松",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "柏偃松俯势自分，森梢古意出浮云。",
            "如今眼暗畫不得，旧有三株持赠君。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 60
    },
    {
        "title": "早夏月夜问王開",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "清风首夏夜犹寒，嫩笋侵阶竹数竿。",
            "君向苏台长见月，不知何事此中看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 61
    },
    {
        "title": "裴十六厅即事",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "主人能政讼庭闲，帆影云峰户牖间。",
            "每到夕阳岚翠近，只言篱障倚前山。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 62
    },
    {
        "title": "春日行营即事",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "风引双旌马首齐，曹南戰胜日平西。",
            "为儒不解从戎事，花落春深闻鼓鼙。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 63
    },
    {
        "title": "畫树后呈浚师",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "翔凤边风十月寒，苍山古木更摧残。",
            "为君壁上畫松柏，劲雪严霜君试看。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 64
    },
    {
        "title": "吊从甥",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "日晚河边访茕独，衰柳寒芜绕茅屋。",
            "儿童惊走报人来，孀妇開门一声哭。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 65
    },
    {
        "title": "句",
        "author": "刘商",
        "biography": "",
        "paragraphs": [
            "邮筒不解献茱萸。。",
            "赵侯首带鹿耳巾，规模出自陶弘景。",
            "。"
        ],
        "notes": [
            ""
        ],
        "volume": "卷三百零四",
        "no#": 66
    }
]